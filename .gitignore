# Terraform state — never commit (environment-specific, can contain secrets)
*.tfstate
*.tfstate.*

# Provider plugins & local working files from `terraform init`
**/.terraform/*

# Crash logs
crash.log
crash.*.log

# Secrets and local-only overrides — never commit.
# Non-secret environment CONFIG is committed via *.auto.tfvars instead.
terraform.tfvars
*.secret.tfvars
secrets.auto.tfvars

# CLI config that can hold credentials
*.tfrc
.terraformrc

# Keep .terraform.lock.hcl committed (not ignored)
